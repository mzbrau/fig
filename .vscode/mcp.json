{
	"servers": {
		"fig-mcp": {
			"type": "stdio",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"${workspaceFolder}/src/mcp/Fig.Mcp/Fig.Mcp.csproj",
				"--no-launch-profile"
			],
			"env": {
				"McpSettings__FigApiBaseUrl": "${input:fig_api_url}",
				"McpSettings__Username": "${input:fig_username}",
				"McpSettings__Password": "${input:fig_password}",
				"McpSettings__Transport": "stdio"
			}
		},
		"chromedevtools/chrome-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"chrome-devtools-mcp@latest",
				"--browserUrl",
				"${input:browser_url}",
				"--headless",
				"${input:headless}",
				"--isolated",
				"${input:isolated}",
				"--channel",
				"${input:chrome_channel}"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		}
	},
	"inputs": [
		{
			"id": "fig_api_url",
			"type": "promptString",
			"description": "Fig API base URL (e.g. https://localhost:7281)",
			"default": "https://localhost:7281"
		},
		{
			"id": "fig_username",
			"type": "promptString",
			"description": "Fig API username",
			"default": "admin"
		},
		{
			"id": "fig_password",
			"type": "promptString",
			"description": "Fig API password",
			"password": true
		},
		{
			"id": "browser_url",
			"type": "promptString",
			"description": "Optional: connect to an already-running Chrome (remote debugging / port-forward). Example: http://127.0.0.1:9222",
			"password": false
		},
		{
			"id": "headless",
			"type": "promptString",
			"description": "Run Chrome headless (true/false). Default: false",
			"password": false,
			"default": "false"
		},
		{
			"id": "isolated",
			"type": "promptString",
			"description": "Use a temporary user-data-dir (true/false). Default: false",
			"password": false,
			"default": "false"
		},
		{
			"id": "chrome_channel",
			"type": "promptString",
			"description": "Chrome channel: stable | canary | beta | dev (default: stable).",
			"password": false,
			"default": "stable"
		}
	]
}
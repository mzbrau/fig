@namespace Fig.Api.Reports.Rendering.Views
@using Fig.Api.Reports.Implementations
@using Fig.Api.Reports.Rendering.Components

@if (Model is not null)
{
    <section class="report-section">
        <h2>Summary</h2>
        <SummaryCards Items="Model.Summary" />
        <p><strong>Scope:</strong> @Model.ScopeDisplay</p>
    </section>

    <section class="report-section">
        <h2>Secret Settings</h2>
        <ReportTable Rows="Model.SecretSettings" Columns="_secretColumns" EmptyMessage="No secret settings found." />
    </section>

    <section class="report-section">
        <h2>Previous Client Secret Windows</h2>
        <ReportTable Rows="Model.PreviousSecretWindows" Columns="_windowColumns" EmptyMessage="No active or recent previous client-secret windows." />
    </section>

    <section class="report-section">
        <h2>API Secret Rotation</h2>
        <SummaryCards Items="Model.ApiRotation" />
    </section>
}

@code {
    [Parameter]
    public SecretHygieneReportModel? Model { get; set; }

    private readonly IReadOnlyList<ReportTableColumn> _secretColumns =
    [
        new("Client", nameof(SecretSettingRow.ClientDisplay)),
        new("Setting", nameof(SecretSettingRow.SettingName)),
        new("Category", nameof(SecretSettingRow.Category)),
        new("Classification", nameof(SecretSettingRow.Classification)),
        new("Last Changed", nameof(SecretSettingRow.LastChanged)),
        new("Age", nameof(SecretSettingRow.Age))
    ];

    private readonly IReadOnlyList<ReportTableColumn> _windowColumns =
    [
        new("Client", nameof(PreviousSecretWindowRow.ClientDisplay)),
        new("Expiry", nameof(PreviousSecretWindowRow.ExpiryUtc)),
        new("Status", nameof(PreviousSecretWindowRow.Status))
    ];
}

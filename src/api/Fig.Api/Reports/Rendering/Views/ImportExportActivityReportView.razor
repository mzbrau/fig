@namespace Fig.Api.Reports.Rendering.Views
@using Fig.Api.Reports.Implementations
@using Fig.Api.Reports.Rendering.Components

@if (Model is not null)
{
    <section class="report-section">
        <h2>Summary</h2>
        <SummaryCards Items="Model.Summary" />
    </section>

    <section class="report-section">
        <h2>Success / Fail</h2>
        <ReportChart Title="" ChartType="doughnut" DatasetLabel="Outcomes" Slices="Model.SuccessFailBreakdown" />
    </section>

    <section class="report-section">
        <h2>Event Details</h2>
        <ReportTable Rows="Model.Rows" Columns="_columns" EmptyMessage="No import/export activity in the selected range." />
    </section>
}

@code {
    [Parameter]
    public ImportExportActivityReportModel? Model { get; set; }

    private readonly IReadOnlyList<ReportTableColumn> _columns =
    [
        new("Timestamp", nameof(ImportExportEventRow.Timestamp)),
        new("Event", nameof(ImportExportEventRow.EventType)),
        new("User", nameof(ImportExportEventRow.User)),
        new("Client", nameof(ImportExportEventRow.ClientDisplay)),
        new("Message", nameof(ImportExportEventRow.Message))
    ];
}

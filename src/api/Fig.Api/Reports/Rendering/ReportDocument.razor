@namespace Fig.Api.Reports.Rendering
@using Microsoft.AspNetCore.Components
@using Fig.Api.Reports

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Context.Title - Fig Report</title>
    <style>@((MarkupString)ReportStyles.CombinedCss)</style>
    <style>@((MarkupString)ReportStyles.BuildPrintFooterCss(Context.GeneratedAtUtc))</style>
</head>
<body class="@(Context.PageOrientation == ReportPageOrientation.Landscape ? "landscape" : "portrait")">
<div class="toolbar no-print">
    <button type="button" onclick="window.print()">Print / Save as PDF</button>
</div>
<div class="report-page">
    <header class="report-header">
        <img class="report-logo" src="@ReportAssets.LogoDataUri" alt="Fig" />
        <div>
            <h1 class="report-title">@Context.Title</h1>
            <p class="report-description">@Context.Description</p>
        </div>
    </header>

    <dl class="report-meta">
        <div>
            <dt>Generated</dt>
            <dd>@Context.GeneratedAtUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</dd>
        </div>
        <div>
            <dt>Generated By</dt>
            <dd>@Context.GeneratedBy</dd>
        </div>
    </dl>

    @if (Context.ParameterSummary.Count > 0)
    {
        <section class="report-params">
            <h2>Parameters</h2>
            <ul>
                @foreach (var pair in Context.ParameterSummary)
                {
                    <li><strong>@pair.Key:</strong> @pair.Value</li>
                }
            </ul>
        </section>
    }

    <main class="report-body">
        <DynamicComponent Type="Context.BodyComponentType" Parameters="BodyParameters" />
    </main>

    <footer class="report-footer">
        Generated by Fig · @Context.GeneratedAtUtc.ToString("u") · Confidential
    </footer>
</div>
</body>
</html>

@code {
    [Parameter, EditorRequired]
    public ReportRenderContext Context { get; set; } = default!;

    private IDictionary<string, object?> BodyParameters =>
        new Dictionary<string, object?> { ["Model"] = Context.Model };
}

@using Fig.Common.Events
@using Fig.Web.Services
@using Fig.Contracts.Authentication
@using Fig.Web.Events
@using Fig.Web.Notifications
@using Fig.Web.Pages.Dialogs
@using Fig.Web.ReleaseHighlights
@using Fig.Web.Components.Assistant
@using Microsoft.Extensions.Options
@using Fig.Web.Facades
@implements IDisposable
@inherits LayoutComponentBase
@inject IAccountService AccountService
@inject IOptions<WebSettings> Settings;
@inject DialogService DialogService;
@inject IEventDistributor EventDistributor;
@inject NavigationManager NavigationManager
@inject IClientStatusFacade ClientStatusFacade
@inject HeaderSearchNavigationState HeaderSearchNavigationState
@inject INotificationHistoryService NotificationHistoryService
@inject IDisplayScriptStatusService DisplayScriptStatusService
@inject IReleaseHighlightsCoordinator ReleaseHighlightsCoordinator

@if (AccountService.IsInitialized)
{
    @if (LoggedIn)
    {
        <!-- nav -->
        <nav class="navbar navbar-expand navbar-dark fig-main-nav">
            <div class="navbar-nav fig-navbar-links">
                <NavLink href="" Match="NavLinkMatch.All" class="nav-item nav-link py-0 px-3">
                    <img src="images/fig_logo_name_right_white_299x135.png" width="90" height="40" />
                </NavLink>
                <NavLink href="" Match="NavLinkMatch.All" class="nav-item nav-link">Settings</NavLink>
                <NavLink href="settingstable" class="nav-item nav-link">Settings Table</NavLink>
                <NavLink href="events" class="nav-item nav-link">Events</NavLink>
                @if (AccountService?.AuthenticatedUser?.Role == Role.Administrator)
                {
                    <NavLink href="groups" class="nav-item nav-link">Groups</NavLink>
                    <NavLink href="users" class="nav-item nav-link">Users</NavLink>
                    <NavLink href="clients" class="nav-item nav-link" style="display: flex; align-items: center; gap: 0.5rem;">
                        Connected Clients
                        @if (ClientStatusFacade.ConnectedClientsCount > 0)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Success" IsPill="true" Text="@ClientStatusFacade.ConnectedClientsCount.ToString()" />
                        }
                    </NavLink>
                    <NavLink href="apistatus" class="nav-item nav-link">API Status</NavLink>
                    <NavLink href="importexport" class="nav-item nav-link">Import / Export</NavLink>
                    <NavLink href="compare" class="nav-item nav-link">Compare</NavLink>
                    <NavLink href="configuration" class="nav-item nav-link">Configuration</NavLink>
                    <NavLink href="webhooks" class="nav-item nav-link">Web Hooks</NavLink>
                    <NavLink href="timemachine" class="nav-item nav-link">Time Machine</NavLink>
                    <NavLink href="scheduling" class="nav-item nav-link">Scheduling</NavLink>
                    <NavLink href="clienthistory" class="nav-item nav-link">Client History</NavLink>
                    <NavLink href="reports" class="nav-item nav-link">Reports</NavLink>
                }
                <NavLink href="lookuptables" class="nav-item nav-link">Lookup Tables</NavLink>
            </div>

            <div class="navbar-nav ms-auto fig-navbar-actions">
                <div class="fig-navbar-action">
                    <RadzenButton Variant="Variant.Text" Click="@ShowKeybindings" Text="Shortcuts" ButtonStyle="ButtonStyle.Light" Icon="help" />
                </div>

                <div class="fig-navbar-action">
                    <RadzenButton Variant="Variant.Flat"
                                  Icon="search"
                                  ButtonStyle="ButtonStyle.Light"
                                  Style="background-color: transparent; color: white; border: none;"
                                  title="Search"
                                  AriaLabel="Search"
                                  Click="@OpenSearchAsync" />
                </div>

                @if (DisplayScriptStatusService.IsProcessing || DisplayScriptStatusService.IsComplete || DisplayScriptStatusService.HasRuns)
                {
                    <button class="fig-navbar-action fig-script-status-action"
                            type="button"
                            aria-label="@(DisplayScriptStatusService.IsProcessing
                                ? "Display scripts are processing. Click to view run history."
                                : "View display script run history")"
                            title="@(DisplayScriptStatusService.IsProcessing
                                ? "Display scripts are processing. Click to view run history."
                                : "View display script run history")"
                            @onclick="ShowDisplayScriptHistory">
                        @if (DisplayScriptStatusService.IsProcessing)
                        {
                            <RadzenProgressBarCircular Size="ProgressBarCircularSize.ExtraSmall"
                                                       Mode="ProgressBarMode.Indeterminate"
                                                       ShowValue="false"
                                                       Style="color: white;" />
                        }
                        else if (DisplayScriptStatusService.IsComplete)
                        {
                            <RadzenIcon Icon="check_circle" Style="color: white; font-size: 1.4rem;" />
                        }
                        else
                        {
                            <RadzenIcon Icon="history" Style="color: white; font-size: 1.4rem;" />
                        }
                    </button>
                }

                <div class="align-content-center p-1 fig-navbar-action fig-notification-action" @onclick="ShowNotificationHistory">
                    <RadzenIcon Icon="notifications" Style="color: white; font-size: 1.4rem;" />
                    @if (NotificationHistoryService.UnreadCount > 0)
                    {
                        <span class="notification-badge">@(NotificationHistoryService.UnreadCount > 99 ? "99+" : NotificationHistoryService.UnreadCount.ToString())</span>
                    }
                </div>
                
                <div class="d-flex flex-column align-items-center justify-content-center p-1 fig-connection-status">
                    <ConnectionStatus/>
                    <p class="mb-0">@Settings.Value.Environment</p>
                </div>

                <RadzenProfileMenu class="fig-profile-menu">
                    <Template>
                        <RadzenImage Path="images/user-icon.png" style="width: 25px"/>
                    </Template>
                    <ChildContent>

                        <p class="text-center fs-3" style="margin: 0">@AccountService?.AuthenticatedUser?.Username</p>
                        <p class="text-center fst-italic">@AccountService?.AuthenticatedUser?.Role</p>
                        <RadzenProfileMenuItem class="match-navbar-background" Text="Account" Path="account/manage" Icon="account_circle"/>
                        <RadzenProfileMenuItem class="match-navbar-background" Text="Logout" Path="account/logout" Icon="logout"/>
                    </ChildContent>
                </RadzenProfileMenu>
            </div>
        </nav>
    }

    <div class="app-container">
        @if (AccountService?.AuthenticatedUser is not null)
        {
            <RadzenNotification />
        }
        <RadzenTooltip/>
        <RadzenDialog/>
        <!-- <Alert />-->
        <ErrorBoundary>
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <ErrorHandlingForm UnhandledException="ex"/>
            </ErrorContent>
        </ErrorBoundary>
        @if (LoggedIn)
        {
            <FigAssistantHost />
        }
    </div>
}
else
{
    <!-- Show loading indicator while authentication is being validated -->
    <div style="display: flex; justify-content: center; align-items: center; height: 100vh; background: #1a1a1a; color: white;">
        <div style="text-align: center;">
            <img src="images/fig_logo_only_500x500.png" alt="Logo" style="max-width: 120px; margin-bottom: 20px;" />
            <div style="margin-top: 20px;">
                <RadzenProgressBarCircular Size="ProgressBarCircularSize.Large" Mode="ProgressBarMode.Indeterminate" />
            </div>
            <p style="margin-top: 20px; font-size: 1.1rem;">Checking authentication...</p>
        </div>
    </div>
}

@code {
    
    private bool LoggedIn => AccountService?.AuthenticatedUser != null;
    private Guid? _releaseHighlightsCheckedUserId;
    private bool _releaseHighlightsDialogOpen;

    private bool IsSettingsPage
    {
        get
        {
            var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
            var path = relativePath.Split(['?', '#'], 2)[0];
            return string.IsNullOrWhiteSpace(path) ||
                   path.Equals("settings", StringComparison.OrdinalIgnoreCase);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        EventDistributor.Subscribe(EventConstants.ClientRunSessionsChanged, StateHasChanged);
        EventDistributor.Subscribe(EventConstants.LogoutEvent, OnLogout);
        NotificationHistoryService.OnChange += OnNotificationChanged;
        DisplayScriptStatusService.OnChange += OnDisplayScriptStatusChanged;
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender)
            await TryOpenReleaseHighlights();
    }

    private void OnNotificationChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnDisplayScriptStatusChanged() => OnNotificationChanged();

    private async Task ShowNotificationHistory()
    {
        await DialogService.OpenAsync<Fig.Web.Pages.Dialogs.NotificationHistoryDialog>(
            "Notification History",
            null,
            new DialogOptions()
            {
                Width = "500px",
                Resizable = true,
                Draggable = true,
                CloseDialogOnOverlayClick = true,
                CloseDialogOnEsc = true,
                Style = "background: #1e1e1e;"
            });
    }

    private async Task ShowDisplayScriptHistory()
    {
        await DialogService.OpenAsync<Fig.Web.Pages.Dialogs.DisplayScriptHistoryDialog>(
            "Display Script Runs",
            null,
            new DialogOptions()
            {
                Width = "90%",
                Height = "80%",
                Resizable = true,
                Draggable = true,
                CloseDialogOnOverlayClick = true,
                CloseDialogOnEsc = true,
                Style = "background: #1e1e1e;"
            });
    }

    private async Task OpenSearchAsync()
    {
        if (IsSettingsPage)
        {
            await EventDistributor.PublishAsync(EventConstants.Search);
            return;
        }

        HeaderSearchNavigationState.RequestOpenSearch();
        NavigationManager.NavigateTo("/");
    }

    private async Task ShowKeybindings()
    {
        await DialogService.OpenAsync($"Keyboard Shortcuts", ds => 
            @<div class="shortcuts-dialog">
                <!-- Documentation Link at the top -->
                <div class="shortcuts-header">
                    <a href="https://figsettings.com" target="_blank" class="documentation-link">
                        <span style="font-size: 18px;">📖</span> View Full Documentation
                    </a>
                </div>

                <!-- Two Column Layout for better space usage -->
                <div class="shortcuts-grid">
                    
                    <!-- Keyboard Shortcuts Section -->
                    <div class="shortcuts-section">
                        <h4>Keyboard Shortcuts</h4>
                        <div class="shortcuts-list">
                            <div class="shortcut-item">
                                <span class="shortcut-key">Alt + S</span>
                                <span>Save Client</span>
                            </div>
                            <div class="shortcut-item">
                                <span class="shortcut-key">Alt + A</span>
                                <span>Save All Clients</span>
                            </div>
                            <div class="shortcut-item">
                                <span class="shortcut-key">Alt + E</span>
                                <span>Expand All</span>
                            </div>
                            <div class="shortcut-item">
                                <span class="shortcut-key">Alt + C</span>
                                <span>Collapse All</span>
                            </div>
                            <div class="shortcut-item">
                                <span class="shortcut-key">Alt + I</span>
                                <span>New Instance</span>
                            </div>
                            <div class="shortcut-item">
                                <span class="shortcut-key">Alt + D</span>
                                <span>Show Client Description</span>
                            </div>
                            <div class="shortcut-item">
                                <span class="shortcut-key">Alt + F</span>
                                <span>Find Settings</span>
                            </div>
                            <div class="shortcut-item">
                                <span class="shortcut-key">Shift × 2</span>
                                <span>Find Settings</span>
                            </div>
                        </div>
                    </div>

                    <!-- Search Syntax Section -->
                    <div class="search-section">
                        <h4>Search Syntax</h4>
                        <p class="search-description">Results must match all search words. By default searches for client, setting, instance.</p>
                        
                        <div class="search-syntax-list">
                            <div class="search-syntax-item">
                                <code class="search-prefix">c:</code>
                                <span>Search only client names</span>
                            </div>
                            <div class="search-syntax-item">
                                <code class="search-prefix">s:</code>
                                <span>Search only setting names</span>
                            </div>
                            <div class="search-syntax-item">
                                <code class="search-prefix">d:</code>
                                <span>Search only descriptions</span>
                            </div>
                            <div class="search-syntax-item">
                                <code class="search-prefix">i:</code>
                                <span>Search only instance names</span>
                            </div>
                            <div class="search-syntax-item">
                                <code class="search-prefix">v:</code>
                                <span>Search only values</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>,
            new DialogOptions() { Resizable = true, Draggable = true, Style = "width: 750px; background: #1e1e1e;"});
    }

    private async Task TryOpenReleaseHighlights()
    {
        if (_releaseHighlightsDialogOpen ||
            AccountService?.AuthenticatedUser?.Role != Role.Administrator ||
            AccountService.AuthenticatedUser.Id is not Guid userId ||
            _releaseHighlightsCheckedUserId == userId)
        {
            return;
        }

        var dialogRequest = await ReleaseHighlightsCoordinator.GetAutoOpenDialog();
        if (!ReleaseHighlightsCoordinator.ShouldRetryAutoOpen)
        {
            _releaseHighlightsCheckedUserId = userId;
        }

        if (dialogRequest == null)
            return;

        _releaseHighlightsDialogOpen = true;
        try
        {
            await DialogService.OpenAsync<ReleaseHighlightsDialog>(
                "What's New",
                new Dictionary<string, object> { ["Request"] = dialogRequest },
                ReleaseHighlightsDialogOptionsFactory.Create());
        }
        finally
        {
            _releaseHighlightsDialogOpen = false;
        }
    }

    private void OnLogout()
    {
        _releaseHighlightsCheckedUserId = null;
        _releaseHighlightsDialogOpen = false;
        ReleaseHighlightsCoordinator.ResetSession();
    }

    public void Dispose()
    {
        EventDistributor.Unsubscribe(EventConstants.ClientRunSessionsChanged, StateHasChanged);
        EventDistributor.Unsubscribe(EventConstants.LogoutEvent, OnLogout);
        NotificationHistoryService.OnChange -= OnNotificationChanged;
        DisplayScriptStatusService.OnChange -= OnDisplayScriptStatusChanged;
    }
}

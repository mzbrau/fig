@using Fig.Contracts.CustomActions
@using Fig.Web.Models.CustomActions
@using Fig.Web.Models.Setting
@using Fig.Common.NetStandard.Json
@using Newtonsoft.Json

@inject ICustomActionsFacade CustomActionsFacade
@inject IJSRuntime JsRuntime
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject NavigationManager NavigationManager

<div class="card mb-3">
    <div class.bind="GetCardHeaderClass()">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@Action.ButtonName</h5>
            @if (Action.LastExecution != null && Action.LastExecution.IsInProgress)
            {
                <div class="spinner-border spinner-border-sm text-light" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            }
        </div>
        <small class="text-muted">@Action.Description</small>
    </div>
    <div class="card-body">
        @if (Action.SettingsUsed.Any())
        {
            <div class="mb-3">
                <h6>Settings:</h6>
                @foreach (var setting in Action.SettingsUsed)
                {
                    <div class="mb-2">
                        <SettingInput @bind-Value="setting.Value"
                                      Definition="setting"
                                      ClientName="@ClientName" 
                                      ShowLabel="true"
                                      ValueChanged="async (o) => await SettingValueChanged(setting, o)"/>
                    </div>
                }
            </div>
        }

        @if (Action.AvailableInstances.Any())
        {
            <div class="mb-3">
                <label for="@($"instance-select-{Action.Name}")" class="form-label">Instance:</label>
                <select id="@($"instance-select-{Action.Name}")" @bind="Action.SelectedInstance" class="form-select form-select-sm">
                    @foreach (var instanceOption in Action.AvailableInstances)
                    {
                        <option value="@instanceOption">@instanceOption</option>
                    }
                </select>
            </div>
        }

        <div class="d-flex justify-content-start align-items-center">
            <button class="btn btn-primary btn-sm me-2" @onclick="ExecuteAction" disabled="@(!Action.CanExecute || Action.IsExecuting)">
                @if (Action.IsExecuting)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    <span class="visually-hidden">Loading...</span>
                }
                else
                {
                    <span>Execute</span>
                }
            </button>
            @if (Action.LastExecution != null && !Action.LastExecution.IsInProgress)
            {
                 <button class="btn btn-outline-secondary btn-sm me-2" @onclick="ToggleLastExecutionResults">
                    @(ShowLastExecutionResults ? "Hide" : "Show") Last Results
                </button>
            }
            <button class="btn btn-outline-info btn-sm" @onclick="ViewHistory">
                History
            </button>
        </div>
        
        @if (Action.LastExecution != null && Action.LastExecution.IsFailed && !string.IsNullOrWhiteSpace(Action.LastExecution.ErrorMessage))
        {
            <div class="alert alert-danger mt-3" role="alert">
                <strong>Error:</strong> @Action.LastExecution.ErrorMessage
            </div>
        }

        @if (ShowLastExecutionResults && Action.LastExecution != null && Action.LastExecution.Results.Any())
        {
            <div class="mt-3">
                <h6>Last Execution Results:</h6>
                @foreach (var result in Action.LastExecution.Results)
                {
                    <CustomActionResultDisplay Result="result" />
                }
            </div>
        }
    </div>
</div>

<Modal @ref="HistoryModal" Title="@($"History for {Action.Name}")" Size="ModalSize.ExtraLarge">
    <Body>
        @if (_selectedActionForHistory != null)
        {
            <CustomActionHistoryView CustomActionId="@_selectedActionForHistory.OriginalContract.Id" 
                                     CustomActionName="@_selectedActionForHistory.Name" />
        }
    </Body>
</Modal>

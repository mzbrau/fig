@using Fig.Web.Models.CustomActions
@using Fig.Web.Facades

@inject ICustomActionsFacade CustomActionsFacade
@inject IJSRuntime JsRuntime

@if (_isLoading)
{
    <p><em>Loading history...</em></p>
}
else if (_history == null || !_history.Executions.Any())
{
    <p><em>No execution history found for @CustomActionName.</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead>
                <tr>
                    <th>Requested At</th>
                    <th>Status</th>
                    <th>Executed At</th>
                    <th>Completed At</th>
                    <th>Error</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var execution in _history.Executions)
                {
                    <tr>
                        <td>@execution.RequestedAt?.ToLocalTime().ToString("g")</td>
                        <td><span class="@GetStatusBadgeClass(execution.Status)">@execution.Status</span></td>
                        <td>@execution.ExecutedAt?.ToLocalTime().ToString("g")</td>
                        <td>@execution.CompletedAt?.ToLocalTime().ToString("g")</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(execution.ErrorMessage))
                            {
                                <span title="@execution.ErrorMessage" class="text-danger">
                                    @Truncate(execution.ErrorMessage, 50)
                                </span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-outline-primary btn-sm" @onclick="() => ViewExecutionDetails(execution.ExecutionId)" disabled="@execution.IsInProgress">
                                Details
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="d-flex justify-content-center mt-3">
        <Paginator CurrentPage="_currentPage" TotalPages="_totalPages" PageChanged="LoadHistoryPage" />
    </div>
}

<Modal @ref="ExecutionDetailsModal" Title="Execution Details" Size="ModalSize.Large">
    <Body>
        @if (_selectedExecutionDetails != null)
        {
            <div class="mb-2"><strong>Execution ID:</strong> @_selectedExecutionDetails.ExecutionId</div>
            <div class="mb-2"><strong>Status:</strong> <span class="@GetStatusBadgeClass(_selectedExecutionDetails.Status)">@_selectedExecutionDetails.Status</span></div>
            <div class="mb-2"><strong>Requested:</strong> @_selectedExecutionDetails.RequestedAt?.ToLocalTime().ToString("F")</div>
            <div class="mb-2"><strong>Executed:</strong> @_selectedExecutionDetails.ExecutedAt?.ToLocalTime().ToString("F")</div>
            <div class="mb-2"><strong>Completed:</strong> @_selectedExecutionDetails.CompletedAt?.ToLocalTime().ToString("F")</div>
            @if (!string.IsNullOrWhiteSpace(_selectedExecutionDetails.ErrorMessage))
            {
                <div class="alert alert-danger"><strong>Error:</strong> @_selectedExecutionDetails.ErrorMessage</div>
            }
            @if (_selectedExecutionDetails.Results.Any())
            {
                <hr />
                <h5>Results:</h5>
                @foreach (var result in _selectedExecutionDetails.Results)
                {
                    <CustomActionResultDisplay Result="result" />
                }
            }
            else if (string.IsNullOrWhiteSpace(_selectedExecutionDetails.ErrorMessage))
            {
                 <p><em>No results were returned for this execution.</em></p>
            }
        }
    </Body>
</Modal>

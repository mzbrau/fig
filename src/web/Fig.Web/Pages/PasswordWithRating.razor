@using System.Globalization
@using Zxcvbn
@inject DialogService DialogService

<div style="display: flex; flex-direction: column; gap: 8px;">
    <div style="display: flex; align-items: center; gap: 10px;">
        @if (_isRevealed)
        {
            <RadzenTextBox @bind-Value="_currentPassword" @oninput="p => PasswordChanged(p.Value?.ToString())" Placeholder="@Placeholder" data-test-id="@TestId" Class="w-100 p-1"/>
        }
        else
        {
            <RadzenPassword @bind-Value="_currentPassword" @oninput="p => PasswordChanged(p.Value?.ToString())" Placeholder="@Placeholder" data-test-id="@TestId" Class="w-100 p-1"/>
        }
        @if (HasPassword)
        {
            <RadzenButton Icon="visibility"
                          ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small"
                          @onmousedown="() => _isRevealed = true"
                          @onmouseup="() => _isRevealed = false"
                          @onmouseleave="() => _isRevealed = false"
                          @ontouchstart="() => _isRevealed = true"
                          @ontouchend="() => _isRevealed = false"
                          Style="min-width: 40px;"
                          title="Hold to reveal password"/>
        }
    </div>

    @if (PasswordStrength >= 0)
    {
        <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 8px;">
            <RadzenBadge BadgeStyle="@StrengthBadgeStyle" Text="@StrengthText"/>

            @if (ShowDetailedFeedback && UseDialogForDetailedFeedback && HasPassword)
            {
                <RadzenButton Text="Details"
                              Icon="info"
                              ButtonStyle="ButtonStyle.Light"
                              Size="ButtonSize.Small"
                              Click="ShowDetailedFeedbackDialog"/>
                <span style="font-size: 0.85rem; opacity: 0.8;">Validated locally in your browser.</span>
            }
        </div>
    }
</div>

@if (ShowInlineDetailedFeedback && !string.IsNullOrEmpty(CrackableMessage))
{
    <p style="white-space: pre-wrap; margin-bottom: 0;">@CrackableMessage</p>
}

@if (ShowInlineDetailedFeedback && !string.IsNullOrWhiteSpace(WarningMessage))
{
    <p style="white-space: pre-wrap; margin-bottom: 0;">@WarningMessage</p>
}

@if (ShowInlineDetailedFeedback && Suggestions.Count > 0)
{
    <ul style="margin-bottom: 0;">
        @foreach (var suggestion in Suggestions)
        {
            <li>@suggestion</li>
        }
    </ul>
}

@if (ShowInlineDetailedFeedback && HasPassword)
{
    <p style="white-space: pre-wrap; margin-bottom: 0;">Password strength is checked locally in your browser using zxcvbn and is not sent to the internet.</p>
    <p style="margin-bottom: 0;">
        Feedback powered by
        <a href="https://github.com/dropbox/zxcvbn" target="_blank" rel="noreferrer">zxcvbn</a>.
    </p>
}

@code {
    
    public int PasswordStrength { get; set; } = -1;
    
    private string _currentPassword = string.Empty;
    private bool _isRevealed = false;
    
    [Parameter]
    public string? TestId { get; set; }

    [Parameter]
    public Action<string> OnValidPassword { get; set; } = _ => { };

    [Parameter]
    public Action<string> OnInvalidPassword { get; set; } = _ => { };

    [Parameter]
    public int MinimumScore { get; set; }

    [Parameter]
    public string Placeholder { get; set; } = string.Empty;

    [Parameter]
    public bool ShowDetailedFeedback { get; set; } = true;

    [Parameter]
    public bool UseDialogForDetailedFeedback { get; set; }

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    private string CrackableMessage { get; set; } = string.Empty;

    private string WarningMessage { get; set; } = string.Empty;

    private List<string> Suggestions { get; set; } = [];

    private string GuessesMessage { get; set; } = string.Empty;

    private string GuessesLog10Message { get; set; } = string.Empty;

    private string CalculationTimeMessage { get; set; } = string.Empty;

    private List<PasswordAnalysisItem> AttackScenarioSummaries { get; set; } = [];

    private bool HasPassword => !string.IsNullOrEmpty(_currentPassword);

    private bool ShowInlineDetailedFeedback => ShowDetailedFeedback && HasPassword && !UseDialogForDetailedFeedback;

    private string StrengthText => PasswordStrength switch
    {
        0 => "Terrible",
        1 => "Poor",
        2 => "Average",
        3 => "Good",
        4 => "Excellent",
        _ => string.Empty
    };

    private BadgeStyle StrengthBadgeStyle => PasswordStrength switch
    {
        0 => BadgeStyle.Danger,
        1 => BadgeStyle.Danger,
        2 => BadgeStyle.Warning,
        3 => BadgeStyle.Info,
        4 => BadgeStyle.Success,
        _ => BadgeStyle.Light
    };

    protected override void OnParametersSet()
    {
        if (ValueChanged.HasDelegate && Value != _currentPassword)
            _currentPassword = Value;
    }

    public void ResetPasswordInformation()
    {
        PasswordStrength = -1;
        CrackableMessage = string.Empty;
        WarningMessage = string.Empty;
        Suggestions = [];
        GuessesMessage = string.Empty;
        GuessesLog10Message = string.Empty;
        CalculationTimeMessage = string.Empty;
        AttackScenarioSummaries = [];
        _currentPassword = string.Empty;
        _isRevealed = false;
    }

    private async Task PasswordChanged(string? password)
    {
        if (string.IsNullOrEmpty(password))
        {
            if (ValueChanged.HasDelegate)
                await ValueChanged.InvokeAsync(string.Empty);

            OnInvalidPassword(string.Empty);
            ResetPasswordInformation();
            return;
        }

        _currentPassword = password;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(password);

        if (ValidatePassword(password))
            OnValidPassword(password);
        else
            OnInvalidPassword(password);
    }

    private bool ValidatePassword(string password)
    {
        var result = Core.EvaluatePassword(password);
        PasswordStrength = result.Score;
        CrackableMessage = $"Crackable in {result.CrackTimeDisplay.OfflineSlowHashing1e4PerSecond}";
        WarningMessage = result.Feedback.Warning ?? string.Empty;
        Suggestions = result.Feedback.Suggestions?.Where(a => !string.IsNullOrWhiteSpace(a)).ToList() ?? [];
        GuessesMessage = FormatGuesses(result.Guesses);
        GuessesLog10Message = result.GuessesLog10.ToString("0.##", CultureInfo.InvariantCulture);
        CalculationTimeMessage = $"{result.CalcTime} ms";
        AttackScenarioSummaries =
        [
            new PasswordAnalysisItem("Throttled online attack", result.CrackTimeDisplay.OnlineThrottling100PerHour),
            new PasswordAnalysisItem("Unthrottled online attack", result.CrackTimeDisplay.OnlineNoThrottling10PerSecond),
            new PasswordAnalysisItem("Offline slow-hash attack", result.CrackTimeDisplay.OfflineSlowHashing1e4PerSecond),
            new PasswordAnalysisItem("Offline fast-hash attack", result.CrackTimeDisplay.OfflineFastHashing1e10PerSecond)
        ];

        return result.Score >= MinimumScore;
    }

    private async Task ShowDetailedFeedbackDialog()
    {
        if (!HasPassword)
            return;

        await DialogService.OpenAsync("Password strength details", ds =>
            @<div style="display: flex; flex-direction: column; gap: 10px;">
                <p style="margin: 0; line-height: 1.5;">
                    Password strength is checked locally in your browser with
                    <a href="https://github.com/dropbox/zxcvbn" target="_blank" rel="noreferrer">zxcvbn</a>.
                    Nothing is sent to the internet for this analysis.
                </p>

                <div style="display: flex; flex-direction: column; gap: 8px; padding: 10px 12px; border: 1px solid rgba(255,255,255,0.12); border-radius: 8px;">
                    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 8px;">
                        <strong>Summary</strong>
                        <RadzenBadge BadgeStyle="@StrengthBadgeStyle" Text="@StrengthText"/>
                    </div>
                    <div style="display: grid; grid-template-columns: minmax(150px, auto) 1fr; gap: 6px 12px; align-items: start;">
                        <strong>Primary estimate</strong>
                        <span>@CrackableMessage</span>
                        <strong>Estimated guesses</strong>
                        <span>@GuessesMessage</span>
                        <strong>guesses_log10</strong>
                        <span>@GuessesLog10Message</span>
                        <strong>Runtime</strong>
                        <span>@CalculationTimeMessage</span>
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 8px; padding: 10px 12px; border: 1px solid rgba(255,255,255,0.12); border-radius: 8px;">
                    <strong>Attack scenarios</strong>
                    <div style="display: grid; grid-template-columns: minmax(180px, auto) 1fr; gap: 6px 12px; align-items: start;">
                        @foreach (var scenario in AttackScenarioSummaries)
                        {
                            <strong>@scenario.Title</strong>
                            <span>@scenario.Detail</span>
                        }
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 8px; padding: 10px 12px; border: 1px solid rgba(255,255,255,0.12); border-radius: 8px;">
                    <strong>Guidance</strong>

                    @if (!string.IsNullOrWhiteSpace(WarningMessage))
                    {
                        <div style="display: flex; flex-direction: column; gap: 4px;">
                            <strong>Headline</strong>
                            <span style="white-space: pre-wrap;">@WarningMessage</span>
                        </div>
                    }

                    @if (Suggestions.Count > 0)
                    {
                        <div style="display: flex; flex-direction: column; gap: 4px;">
                            <strong>Suggestions</strong>
                            <ul style="margin: 0;">
                                @foreach (var suggestion in Suggestions)
                                {
                                    <li>@suggestion</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (string.IsNullOrWhiteSpace(WarningMessage) && Suggestions.Count == 0)
                    {
                        <span>No additional warnings or suggestions were generated for this password.</span>
                    }
                </div>

                <div class="d-flex justify-content-end">
                    <RadzenButton Text="Close" Click="() => ds.Close()" ButtonStyle="ButtonStyle.Secondary"/>
                </div>
            </div>,
            new DialogOptions
            {
                Width = "680px",
                CloseDialogOnOverlayClick = true,
                CloseDialogOnEsc = true,
                Resizable = true,
                Draggable = true,
                Style = "background: #1e1e1e; max-width: calc(100vw - 2rem); max-height: calc(100vh - 2rem); overflow-y: auto;"
            });
    }

    private static string FormatGuesses(double guesses)
    {
        if (guesses < 1000)
            return guesses.ToString("0", CultureInfo.InvariantCulture);

        if (guesses < 1000000)
            return guesses.ToString("N0", CultureInfo.InvariantCulture);

        return guesses.ToString("0.###e+0", CultureInfo.InvariantCulture);
    }

    private sealed record PasswordAnalysisItem(string Title, string Detail);
}
